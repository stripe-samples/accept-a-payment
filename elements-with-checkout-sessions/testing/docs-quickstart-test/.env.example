# Copy this file to .env and fill in your Stripe test keys.
# Get your keys at https://dashboard.stripe.com/test/apikeys

STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# A Price ID from your Stripe dashboard (test mode).
# Create one at https://dashboard.stripe.com/test/products
STRIPE_PRICE_ID=price_...
